# --- Required ---
# MongoDB Atlas (or any MongoDB reachable from Railway). No localhost in production.
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/DATABASE?retryWrites=true&w=majority

# Long random string for JWT signing
JWT_SECRET=replace-with-a-long-random-secret

# Railway sets PORT automatically. Optional locally:
PORT=8080

NODE_ENV=production

# --- CORS ---
# Comma-separated list of allowed browser origins (your Vercel URL + custom domain).
# Example: https://swimax-system.vercel.app,https://app.yourdomain.com
ALLOWED_ORIGINS=

# --- Optional: Cloudinary (coach/trainee images) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Dangerous: default admin bootstrap ---
# Only set to true temporarily if you need the default manager user created.
# Default is OFF. Never enable in production unless you change credentials immediately after.
SEED_DEFAULT_ADMIN=false
